# Copie para .env e ajuste. NUNCA versione o .env nem credenciais.

# --- BigQuery / GCP ---
GOOGLE_CLOUD_PROJECT="seu-projeto-gcp"
GCP_DATASET_ID="promozone"
BQ_TABLE="promotions"
# dataset, load jobs e MERGE precisam usar a MESMA location.
BQ_LOCATION="southamerica-east1"

# Credenciais (apenas LOCAL). No Cloud Run usamos ADC (service account anexada),
# sem key dentro do container.
# GOOGLE_APPLICATION_CREDENTIALS="secrets/sa.json"

# --- Coleta (opcional; têm defaults sensatos em app/core/config.py) ---
# SOURCES aceita CSV: "https://...ofertas,https://...ofertas?category=MLB1051"
# SOURCES="https://www.mercadolivre.com.br/ofertas"
# MAX_PAGES_PER_SOURCE=5
# DELAY_BETWEEN_PAGES_SECONDS=1.5

# --- Logging ---
LOG_LEVEL="INFO"
